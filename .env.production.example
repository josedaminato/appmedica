# AppMedica — variables de producción (Hostinger VPS)
# Copiar a .env en el servidor: cp .env.production.example .env

# === Dominio (para CORS; sin barra final) ===
# Ejemplo: https://app.tudominio.com
PUBLIC_URL=https://app.tudominio.com
CORS_ORIGINS=https://app.tudominio.com

# Frontend: ruta relativa al mismo dominio (nginx proxy /api → backend)
VITE_API_URL=/api/v1

# === Base de datos (PostgreSQL en Docker) ===
POSTGRES_USER=appmedica
POSTGRES_PASSWORD=CAMBIAR-password-largo-y-aleatorio
POSTGRES_DB=appmedica
DATABASE_URL=postgresql+psycopg://appmedica:CAMBIAR-password-largo-y-aleatorio@db:5432/appmedica

# === Backend ===
JWT_SECRET=CAMBIAR-generar-string-largo-aleatorio-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
APP_ENV=production
LOG_LEVEL=INFO
UVICORN_RELOAD=0
# KVM 1 (1 vCPU): usar 1 worker. KVM 2+ puede subir a 2.
UVICORN_WORKERS=1

# Demo: 0 en producción real; 1 solo para staging/primera prueba
SEED_DEMO=0

# Puerto HTTP expuesto (80 en VPS; Hostinger suele usar 80/443)
HTTP_PORT=80
