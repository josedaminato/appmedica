# Referencia local — copiar a deploy/vps.local.env (está en .gitignore; NO commitear)
# Valores reales de producción van en backend/.env.prod (copiar al VPS en /opt/appmedica/backend/.env.prod)

VPS_IP=IP_DEL_VPS
VPS_SSH=ssh root@IP_DEL_VPS
VPS_HOSTNAME=hostname.hstgr.cloud

POSTGRES_USER=appmedica
POSTGRES_PASSWORD=CAMBIAR-password-largo-y-aleatorio
POSTGRES_DB=appmedica

JWT_SECRET=CAMBIAR-ejecutar-openssl-rand-hex-32

# URL pública de la app (el backend lee PUBLIC_APP_URL, no APP_URL)
PUBLIC_APP_URL=https://app.daminatoweb.com
CORS_ORIGINS=https://app.daminatoweb.com

DNS_APP=A app → IP_DEL_VPS
