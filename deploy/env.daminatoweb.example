# AppMedica — producción daminatoweb.com (VPS compartido solo a nivel servidor)
# Copiar: cp deploy/env.daminatoweb.example .env

COMPOSE_PROJECT_NAME=appmedica

# Solo AppMedica / daminatoweb — sin relación con otros dominios en el mismo VPS
PUBLIC_URL=https://app.daminatoweb.com
CORS_ORIGINS=https://app.daminatoweb.com

VITE_API_URL=/api/v1

POSTGRES_USER=appmedica
POSTGRES_PASSWORD=CAMBIAR-password-largo-y-aleatorio
POSTGRES_DB=appmedica
DATABASE_URL=postgresql+psycopg://appmedica:CAMBIAR-password-largo-y-aleatorio@db:5432/appmedica

JWT_SECRET=CAMBIAR-generar-string-largo-aleatorio-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
APP_ENV=production
LOG_LEVEL=INFO
UVICORN_RELOAD=0
UVICORN_WORKERS=1

SEED_DEMO=0

# Puerto LOCAL del contenedor web (no choca con otros proyectos en :80)
# nginx del host redirige app.daminatoweb.com → 127.0.0.1:8082
HTTP_PORT=8082
