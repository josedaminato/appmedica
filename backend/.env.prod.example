# AppMedica — variables de producción
# Copiar en el servidor:
#   cp backend/.env.prod.example backend/.env.prod
#   nano backend/.env.prod
#
# Generar JWT_SECRET:
#   openssl rand -hex 32

# === PostgreSQL (servicio db en Docker) ===
POSTGRES_USER=appmedica
POSTGRES_PASSWORD=CAMBIAR-password-largo-y-aleatorio
POSTGRES_DB=appmedica

# URL interna (host "db" = nombre del servicio en docker-compose)
DATABASE_URL=postgresql+psycopg://appmedica:CAMBIAR-password-largo-y-aleatorio@db:5432/appmedica

# === JWT / seguridad ===
# La app lee JWT_SECRET (no SECRET_KEY). Equivalente a SECRET_KEY en otros frameworks.
JWT_SECRET=CAMBIAR-ejecutar-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# === Entorno ===
# La app lee APP_ENV (no ENVIRONMENT). Usar "production" en el VPS.
APP_ENV=production
LOG_LEVEL=INFO

# === CORS (dominio público, sin barra final) ===
CORS_ORIGINS=https://app.daminatoweb.com

# === Rate limiting (anti fuerza bruta en login/registro/recuperar) ===
# Formato slowapi: "N/segundo|minuto|hora|día". Por IP.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/hour
RATE_LIMIT_PASSWORD_RESET=5/minute

# === Frontend (build-time en Docker) ===
VITE_API_URL=https://app.daminatoweb.com/api/v1

# === Uvicorn ===
UVICORN_RELOAD=0
# KVM 1 vCPU: 1 worker. VPS con más CPU puede usar 2.
UVICORN_WORKERS=1

# === Seed demo ===
# 0 en producción real. 1 solo para primera prueba o staging.
SEED_DEMO=0

# Recordatorios — costo $0: WhatsApp manual (botón en agenda), email opcional vía SMTP Hostinger
REMINDERS_ENABLED=true
REMINDER_HOURS_BEFORE=24
EMAIL_PROVIDER=mock
WHATSAPP_PROVIDER=disabled
PUBLIC_APP_URL=https://app.daminatoweb.com

# Resumen nocturno: agenda del día siguiente por email (profesional / dueño)
DAILY_AGENDA_DIGEST_ENABLED=true
DAILY_AGENDA_DIGEST_HOUR=21
DAILY_AGENDA_DIGEST_MINUTE=0

# Feed iCal (Google Calendar / Outlook) — $0, solo lectura
# CALENDAR_FEED_DAYS_PAST=7
# CALENDAR_FEED_DAYS_FUTURE=90

# Opcional email automático gratis:
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=587
# SMTP_USER=noreply@daminatoweb.com
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@daminatoweb.com
