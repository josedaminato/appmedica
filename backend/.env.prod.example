# AppMedica — variables de producción
# Copiar en el servidor:
#   cp backend/.env.prod.example backend/.env.prod
#   nano backend/.env.prod
#
# Generar JWT_SECRET:
#   openssl rand -hex 32

# === PostgreSQL (servicio db en Docker) ===
POSTGRES_USER=appmedica
POSTGRES_PASSWORD=CAMBIAR-password-largo-y-aleatorio
POSTGRES_DB=appmedica

# URL interna (host "db" = nombre del servicio en docker-compose)
DATABASE_URL=postgresql+psycopg://appmedica:CAMBIAR-password-largo-y-aleatorio@db:5432/appmedica

# === JWT / seguridad ===
# La app lee JWT_SECRET (no SECRET_KEY). Equivalente a SECRET_KEY en otros frameworks.
JWT_SECRET=CAMBIAR-ejecutar-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# === Entorno ===
# La app lee APP_ENV (no ENVIRONMENT). Usar "production" en el VPS.
APP_ENV=production
LOG_LEVEL=INFO

# === CORS (dominio público, sin barra final) ===
CORS_ORIGINS=https://app.daminatoweb.com

# === Frontend (build-time en Docker) ===
VITE_API_URL=https://app.daminatoweb.com/api/v1

# === Uvicorn ===
UVICORN_RELOAD=0
# KVM 1 vCPU: 1 worker. VPS con más CPU puede usar 2.
UVICORN_WORKERS=1

# === Seed demo ===
# 0 en producción real. 1 solo para primera prueba o staging.
SEED_DEMO=0
