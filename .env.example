# Database
POSTGRES_USER=appmedica
POSTGRES_PASSWORD=appmedica_secret
POSTGRES_DB=appmedica
DATABASE_URL=postgresql+psycopg://appmedica:appmedica_secret@db:5432/appmedica

# Backend
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
APP_ENV=development
LOG_LEVEL=INFO

# Frontend (Vite)
VITE_API_URL=http://localhost:8000/api/v1

# Backend: 1 = uvicorn --reload (más lento en OneDrive). 0 = estable (recomendado)
UVICORN_RELOAD=0

# Si el puerto 8000 quedó bloqueado por un contenedor zombie, usá 8001 y reiniciá compose:
# BACKEND_HOST_PORT=8001
# VITE_API_URL=http://localhost:8001/api/v1
BACKEND_HOST_PORT=8000

# Recordatorios — costo mínimo: WhatsApp manual en agenda (wa.me), email mock hasta SMTP
REMINDERS_ENABLED=true
REMINDER_HOURS_BEFORE=24
REMINDER_BACKGROUND_LOOP=true
EMAIL_PROVIDER=mock
WHATSAPP_PROVIDER=disabled
PUBLIC_APP_URL=http://localhost:5173
# Email gratis con Hostinger: EMAIL_PROVIDER=smtp + SMTP_* (ver docs/REMINDERS.md)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
